SPRING_PROFILES_ACTIVE=dev
APP_TIME_ZONE=America/Guayaquil
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5432/forze
DB_USERNAME=postgres
DB_PASSWORD=change-me

FLYWAY_URL=jdbc:postgresql://localhost:5432/forze
FLYWAY_USER=postgres
FLYWAY_PASSWORD=change-me

JWT_ISSUER=forze-backend
# HMAC-SHA key: must be >= 256 bits (>= 32 bytes). Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes-0000
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=2592000000

ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=change-me

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OPENAPI_ENABLED=true
ACTUATOR_HEALTH_SHOW_DETAILS=never

TRACING_ENABLED=true
TRACING_SAMPLING_PROBABILITY=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=forze-backend
